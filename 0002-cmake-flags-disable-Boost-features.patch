From 3fe0d2e40fbc37fa0694850d272b16dc5bae2874 Mon Sep 17 00:00:00 2001
From: Scott K Logan <logans@cottsay.net>
Date: Wed, 13 May 2026 22:41:56 -0400
Subject: [PATCH 2/2] cmake flags: disable Boost features

Co-authored-by: Jose Luis Blanco-Claraco <joseluisblancoc@gmail.com>
---
 rpm/ros-lyrical-gtsam.spec | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/rpm/ros-lyrical-gtsam.spec b/rpm/ros-lyrical-gtsam.spec
index 7611bb21fc08..becb7087285a 100644
--- a/rpm/ros-lyrical-gtsam.spec
+++ b/rpm/ros-lyrical-gtsam.spec
@@ -57,6 +57,8 @@ gtsam
     -DCMAKE_PREFIX_PATH="%{bloom_prefix}" \
     -DSETUPTOOLS_DEB_LAYOUT=OFF \
     -DGTSAM_USE_SYSTEM_EIGEN=ON \
+    -DGTSAM_ENABLE_BOOST_SERIALIZATION=OFF \
+    -DGTSAM_USE_BOOST_FEATURES=OFF \
 %if !0%{?with_tests}
     -DBUILD_TESTING=OFF \
 %endif
